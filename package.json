{
	"type": "module",
	"name": "my-sveltekit-app",
	"private": true,
	"version": "0.0.1",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "vite build",
		"bddgen": "bddgen -c playwright.config.ts",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:check": "drizzle-kit check",
		"db:generate": "drizzle-kit generate",
		"deploy": "alchemy deploy",
		"destroy": "alchemy destroy",
		"dev": "alchemy dev",
		"format": "prettier --write . --cache",
		"lint": "prettier --check . && eslint .",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"test": "vitest run",
		"test:component": "vitest run tests/component",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run tests/unit",
		"test:watch": "vitest",
		"test:e2e": "pnpm bddgen && playwright test",
		"test:e2e:ui": "pnpm bddgen && playwright test --ui"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.18",
		"@cloudflare/workers-types": "^4.20260228.0",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "9",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "24",
		"@vitest/coverage-v8": "^4.0.18",
		"alchemy": "link:../alchemy/alchemy",
		"drizzle-kit": "1.0.0-beta.15-859cf75",
		"eslint": "9",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.3.0",
		"jsdom": "^28.1.0",
		"miniflare": "^4.20260219.0",
		"playwright-bdd": "^8.4.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.0",
		"svelte-check": "^4.4.3",
		"tailwindcss": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"better-auth": "^1.4.18",
		"drizzle-orm": "1.0.0-beta.15-859cf75",
		"valibot": "^1.2.0"
	}
}
